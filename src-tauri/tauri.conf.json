{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "browser-switch",
  "version": "0.1.0",
  "identifier": "com.krip.browser-switch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "browser-switch",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "category": "Productivity",
    "shortDescription": "AI bookmark organizer",
    "longDescription": "AI bookmark organizer for Chrome and Firefox"
  }
}
